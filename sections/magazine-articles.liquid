{%- liquid
  assign enable_animation = section.settings.enable_animation
  assign show_category = section.settings.show_category

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'mb-8 lg:mb-14'
    when 'large'
      assign margin_class = 'mb-14 lg:mb-20'
  endcase

  comment
    Data source: blocks override blog setting
  endcomment
  assign use_blocks = false
  if section.blocks.size > 0
    assign use_blocks = true
  endif
-%}

<section class="page-block relative page-block--magazine-articles {{ margin_class }} bg-transparent" id="magazine-articles-{{ section.id }}">

  {%- comment -%} Top content — heading + subheading with its own InView {%- endcomment -%}
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div {% if enable_animation %}data-inview="false"{% else %}data-inview="true"{% endif %}
         class="group-inview group/blocks">
      <div class="container mb-8 text-center lg:mb-10
                  opacity-0 -translate-y-14 transition-all duration-1000 ease animation-group
                  group-data-[inview=true]/blocks:opacity-100
                  group-data-[inview=true]/blocks:translate-y-0">
        {%- if section.settings.heading != blank -%}
          <h2>
            <span class="font-serif">
              <span class="text-4xl lg:text-5xl">{{ section.settings.heading }}</span>
            </span>
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="rte">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Carousel — wrapped in its own InView for card stagger animations {%- endcomment -%}
  <div class="container-wide">
    <div {% if enable_animation %}data-inview="false"{% else %}data-inview="true"{% endif %}
         class="group-inview group/blocks">
      <div class="splide" data-magazine-carousel>
        <div class="splide__track">
          <ul class="splide__list">
            {%- if use_blocks -%}
              {%- for block in section.blocks -%}
                {%- assign article = block.settings.article -%}
                {%- if article != blank -%}
                  <li class="splide__slide" {{ block.shopify_attributes }}>
                    <div style="transition-delay: calc(var(--base-delay, 0ms) + {{ forloop.index0 | times: 90 }}ms)"
                         class="opacity-0 scale-75 transition-all duration-1000 animation-group
                                group-data-[inview=true]/blocks:opacity-100
                                group-data-[inview=true]/blocks:scale-100">
                      {%- render 'magazine-card', article: article, show_category: show_category -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            {%- elsif section.settings.blog != blank -%}
              {%- for article in section.settings.blog.articles limit: section.settings.article_count -%}
                <li class="splide__slide">
                  <div style="transition-delay: calc(var(--base-delay, 0ms) + {{ forloop.index0 | times: 90 }}ms)"
                       class="opacity-0 scale-75 transition-all duration-1000 animation-group
                              group-data-[inview=true]/blocks:opacity-100
                              group-data-[inview=true]/blocks:scale-100">
                    {%- render 'magazine-card', article: article, show_category: show_category -%}
                  </div>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>
      </div>

      {%- comment -%} Optional CTA button {%- endcomment -%}
      {%- if section.settings.button_label != blank -%}
        <div class="flex justify-center pt-10">
          <a href="{{ section.settings.button_link }}"
             class="flex items-center gap-2 text-center text-sm tracking-wider transition-all uppercase text-taupe-900">
            <span>{{ section.settings.button_label }}</span>
            {%- render 'icon', icon: 'chevron-right', size: 'size-4' -%}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>

</section>

<script>
  (function () {
    var section = document.getElementById('magazine-articles-{{ section.id }}');
    if (!section) return;

    var enableAnimation = {{ enable_animation | json }};

    /* Intersection observer — flip data-inview on each observer group */
    if (enableAnimation) {
      var groups = section.querySelectorAll('[data-inview]');
      if (groups.length) {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-inview', 'true');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.3, rootMargin: '0px 0px -20%' }
        );
        groups.forEach(function (el) {
          observer.observe(el);
        });
      }
    }

    /* Splide init */
    var el = section.querySelector('[data-magazine-carousel]');
    if (el && typeof Splide !== 'undefined') {
      new Splide(el, {
        perPage: 3,
        gap: '1.25rem',
        arrows: false,
        pagination: false,
        breakpoints: {
          480:  { perPage: 1, padding: { left: 0, right: '15%' } },
          768:  { perPage: 2, padding: { left: 0, right: '10%' } },
          1024: { perPage: 3, padding: { left: 0, right: '10%' } }
        }
      }).mount();
    }
  })();
</script>

{% schema %}
{
  "name": "Magazine articles",
  "tag": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog",
      "info": "Select a blog to show latest articles. Add article blocks below to override with specific posts."
    },
    {
      "type": "range",
      "id": "article_count",
      "label": "Number of articles",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3,
      "info": "Only used when no article blocks are added"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Magazine"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category tag",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Magazine articles"
    }
  ]
}
{% endschema %}
