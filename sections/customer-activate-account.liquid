{% comment %}
  Customer activate account — single-column card over full-bleed background.
  Reached from the account-invitation email. Handled entirely by Shopify.
{% endcomment %}

<div class="relative py-20 md:flex md:min-h-[80dvh] md:flex-col md:justify-center">
  <div class="container relative z-1 flex flex-col items-center">
    <div class="w-full max-w-md bg-taupe-300 px-8 py-10 md:px-14">
      <h1 class="mb-4 text-center font-serif text-3xl lg:text-4xl">Activate your account</h1>
      <p class="mb-6 text-center text-sm">Create a password to activate your account.</p>

      {%- form 'activate_customer_password' -%}
        {%- if form.errors -%}
          <div class="mb-4 border border-red-600 bg-red-100 p-3 text-sm text-red-700">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="mb-4">
          {% render 'form-input',
            name: 'customer[password]',
            label: 'Password',
            type: 'password',
            required: true,
            autocomplete: 'new-password'
          %}
        </div>

        <div class="mb-6">
          {% render 'form-input',
            name: 'customer[password_confirmation]',
            label: 'Confirm password',
            type: 'password',
            required: true,
            autocomplete: 'new-password'
          %}
        </div>

        <div class="mb-4 flex justify-center">
          {% render 'form-button', label: 'Activate account', type: 'submit', full_width: true %}
        </div>

        <div class="flex justify-center">
          <button type="submit" name="decline" class="text-sm tracking-wider underline transition-colors hover:text-clubhouse-green-600">
            Decline invitation
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>

  {%- if section.settings.background_image != blank -%}
    <img
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      alt="{{ section.settings.background_image.alt | default: '' }}"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
      class="absolute left-0 top-0 size-full object-cover"
      loading="eager"
    >
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Customer activate account",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Full-bleed background image"
    }
  ]
}
{% endschema %}
