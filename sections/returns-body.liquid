{%- liquid
  assign enable_animation = section.settings.enable_animation
-%}

<section class="page-block relative page-block--content lg:mb-14 mb-8 bg-transparent{% unless enable_animation %} [&_.group-inview_.animation-group]:!translate-x-0 [&_.group-inview_.animation-group]:!translate-y-0 [&_.group-inview_.animation-group]:!scale-100 [&_.group-inview_.animation-group]:!opacity-100 [&_.group-inview_.animation-group]:!transition-none [&_.group-inview_.animation-group]:!duration-0{% endunless %}"
  id="returns-body-{{ section.id }}">
  <div data-inview="false" class="group-inview group/blocks">
    <div class="container-narrow text-left">
      <div class="rte opacity-0 -translate-y-14 transition-all duration-1000 ease animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:translate-y-0 [&_h1]:!font-serif [&_h1]:!text-4xl lg:[&_h1]:!text-5xl [&_h2]:!text-3xl lg:[&_h2]:!text-4xl [&_h3]:!text-xl lg:[&_h3]:!text-2xl [&_p]:mb-4 [&_strong]:font-bold">
        {{ section.settings.body_content }}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('returns-body-{{ section.id }}');
    if (!section) return;

    var enableAnimation = {{ enable_animation | json }};
    if (!enableAnimation) return;

    var wrapper = section.querySelector('[data-inview]');
    if (!wrapper) return;

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.setAttribute('data-inview', 'true');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3, rootMargin: '0px 0px -20%' }
    );
    observer.observe(wrapper);
  })();
</script>

{% schema %}
{
  "name": "Returns page body",
  "tag": "section",
  "class": "returns-body-section",
  "settings": [
    {
      "type": "richtext",
      "id": "body_content",
      "label": "Content",
      "default": "<h1>Returns &amp; exchanges</h1>"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll-in animation",
      "default": false
    }
  ]
}
{% endschema %}
