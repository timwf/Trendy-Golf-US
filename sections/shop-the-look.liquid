{%- liquid
  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'mb-8 lg:mb-14'
    when 'large'
      assign margin_class = 'mb-14 lg:mb-20'
  endcase
-%}

<section class="shop-the-look relative {{ margin_class }}" id="shop-the-look-{{ section.id }}">
  <div class="container-wide">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-10 lg:gap-16">

      {%- comment -%} Left — hero image with text overlay {%- endcomment -%}
      <div class="relative flex flex-col">
        <div class="relative min-h-[280px] flex-1 overflow-hidden bg-taupe-300">
          {%- if section.settings.image != blank -%}
            <picture>
              {%- if section.settings.mobile_image != blank -%}
                <source
                  media="(max-width: 767px)"
                  srcset="{{ section.settings.mobile_image | image_url: width: 480 }} 480w,
                          {{ section.settings.mobile_image | image_url: width: 750 }} 750w"
                  sizes="100vw">
              {%- endif -%}
              <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                        {{ section.settings.image | image_url: width: 800 }} 800w,
                        {{ section.settings.image | image_url: width: 1200 }} 1200w"
                sizes="(min-width: 768px) 50vw, 100vw"
                alt="{{ section.settings.title | escape }}"
                width="{{ section.settings.image.width }}"
                height="{{ section.settings.image.height }}"
                loading="lazy"
                class="absolute left-0 top-0 size-full object-cover">
            </picture>

            {%- comment -%} Overlay + blur {%- endcomment -%}
            <div class="absolute left-0 top-0 z-1 size-full bg-black/10 pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 z-1 h-3/5 w-full pointer-events-none
                        [mask-image:linear-gradient(to_top,black,transparent)]
                        [-webkit-mask-image:linear-gradient(to_top,black,transparent)]
                        backdrop-blur-[10px]"></div>
          {%- endif -%}

          {%- comment -%} Text overlay {%- endcomment -%}
          <div class="relative z-2 flex min-h-[280px] flex-1 flex-col justify-end p-6 md:p-8">
            {%- if section.settings.title != blank -%}
              <h2 class="mb-6 text-left text-[2.125rem] font-normal uppercase leading-none text-white lg:text-[4.5rem]">
                {{ section.settings.title | escape }}
              </h2>
            {%- endif -%}

            <div class="flex flex-wrap items-end justify-between gap-4">
              {%- if section.settings.subtext != blank -%}
                <p class="mb-0 hidden text-sm font-medium uppercase tracking-wider text-white md:block lg:text-base">
                  {{ section.settings.subtext | escape }}
                </p>
              {%- endif -%}

              {%- if section.settings.btn_link != blank and section.settings.btn_text != blank -%}
                <a href="{{ section.settings.btn_link }}"
                   class="ml-auto hidden whitespace-nowrap bg-white px-4 py-2 text-sm font-semibold uppercase text-black transition-colors hover:bg-taupe-300 md:inline-block">
                  {{ section.settings.btn_text | escape }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>

        {%- comment -%} Mobile subtext — below image {%- endcomment -%}
        {%- if section.settings.subtext != blank -%}
          <p class="mt-4 text-center text-sm font-medium uppercase tracking-wider md:hidden">
            {{ section.settings.subtext | escape }}
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} Right — product grid (2x2) {%- endcomment -%}
      <div class="flex flex-col">
        <div class="grid grid-cols-2 gap-x-1 gap-y-5 md:gap-x-5 md:gap-y-7">
          {%- for block in section.blocks -%}
            <div {{ block.shopify_attributes }}>
              {%- if block.settings.product != blank -%}
                {%- render 'product-card', product: block.settings.product -%}
              {%- else -%}
                <div class="flex aspect-[9/12] items-center justify-center bg-taupe-300 text-sm text-taupe-700">
                  {{ 'product-1' | placeholder_svg_tag: 'w-1/2 h-1/2 text-taupe-400' }}
                </div>
                <div class="mt-4 px-3 text-center md:mt-5">
                  <p class="mb-1 text-xs font-semibold tracking-wider text-taupe-700 md:text-sm">Product</p>
                  <p class="text-base text-taupe-600">Not available</p>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Mobile CTA — below products {%- endcomment -%}
        {%- if section.settings.btn_link != blank and section.settings.btn_text != blank -%}
          <div class="mt-6 text-center md:hidden">
            <a href="{{ section.settings.btn_link }}"
               class="text-sm font-semibold uppercase tracking-wider">
              {{ section.settings.btn_text | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the Look",
  "tag": "section",
  "class": "shop-the-look-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 1260 x 1400px"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended: 750 x 830px"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
