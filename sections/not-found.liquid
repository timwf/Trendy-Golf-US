{%- liquid
  assign heading = section.settings.heading | default: 'Out of bounds'
  assign body = section.settings.body | default: 'This page missed the fairway. Head home to explore our latest collections and get back in style.'
  assign button_label = section.settings.button_label | default: 'Back to home'
  assign button_url = section.settings.button_url | default: '/'

  if section.settings.background_image != blank
    assign bg_url = section.settings.background_image | image_url: width: 2400
    assign bg_alt = section.settings.background_image.alt | default: 'golf green'
    assign bg_width = section.settings.background_image.width
    assign bg_height = section.settings.background_image.height
  else
    assign bg_url = '404-golf-green.jpg' | asset_url
    assign bg_alt = 'golf green'
    assign bg_width = 2400
    assign bg_height = 1600
  endif
-%}

<div class="relative">
  <div class="container relative z-1 flex min-h-[70dvh] flex-col justify-center text-center">
    <div class="mb-6 text-white">
      <h1 class="text-5xl lg:text-6xl font-serif">{{ heading }}</h1>
      <p>{{ body }}</p>
    </div>
    <div>
      <div class="inline-block">
        <a
          href="{{ button_url }}"
          class="flex items-center gap-2 text-center text-sm tracking-wider transition-all uppercase justify-center px-4 py-3 lg:px-10 min-w-40 bg-white text-taupe-900 hover:bg-neutral-100"
        >
          {{ button_label }}
        </a>
      </div>
    </div>
  </div>
  <img
    src="{{ bg_url }}"
    alt="{{ bg_alt | escape }}"
    width="{{ bg_width }}"
    height="{{ bg_height }}"
    class="absolute left-0 top-0 size-full object-cover"
    loading="eager"
    fetchpriority="high"
  >
</div>

{% schema %}
{
  "name": "404 content",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Out of bounds"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This page missed the fairway. Head home to explore our latest collections and get back in style."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Back to home"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link",
      "default": "/"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Defaults to the packaged golf green image when empty."
    }
  ]
}
{% endschema %}