{%- liquid
  assign enable_animation = section.settings.enable_animation

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'mb-8 lg:mb-14'
    when 'large'
      assign margin_class = 'mb-14 lg:mb-20'
  endcase

  assign media_first_desktop = section.settings.media_first_desktop
  assign media_first_mobile = section.settings.media_first_mobile
  assign media_type = section.settings.media_type

  if media_first_mobile
    assign media_order_mobile = 'order-1'
    assign text_order_mobile = 'order-2'
  else
    assign media_order_mobile = 'order-2'
    assign text_order_mobile = 'order-1'
  endif

  if media_first_desktop
    assign media_order_desktop = 'md:order-1'
    assign text_order_desktop = 'md:order-2'
  else
    assign media_order_desktop = 'md:order-2'
    assign text_order_desktop = 'md:order-1'
  endif

  if media_type == 'embed' and section.settings.embed != blank
    if section.settings.embed.type == 'youtube'
      assign embed_src = 'https://www.youtube.com/embed/' | append: section.settings.embed.id
    elsif section.settings.embed.type == 'vimeo'
      assign embed_src = 'https://player.vimeo.com/video/' | append: section.settings.embed.id
    endif
  endif

  case section.settings.btn_style
    when 'button--primary'
      assign btn_class = 'inline-block bg-taupe-900 text-white px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-600'
    when 'button--primary button--inverse'
      assign btn_class = 'inline-block bg-white text-taupe-900 px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-100'
    when 'button--primary button--outlined'
      assign btn_class = 'inline-block border border-taupe-900 text-taupe-900 px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-900 hover:text-white'
    when 'button--secondary'
      assign btn_class = 'inline-block text-taupe-900 underline underline-offset-4 text-sm uppercase tracking-wider hover:text-taupe-600'
    when 'button--secondary button--inverse'
      assign btn_class = 'inline-block text-white underline underline-offset-4 text-sm uppercase tracking-wider hover:text-taupe-100'
    when 'button--secondary button--outlined'
      assign btn_class = 'inline-block border border-taupe-900 text-taupe-900 px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-900 hover:text-white'
    else
      assign btn_class = 'inline-block bg-taupe-900 text-white px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-600'
  endcase
-%}

<section class="media-text-section relative {{ margin_class }}" id="media-text-{{ section.id }}">
  <div class="container-wide" {% if section.settings.max_width != blank %}style="max-width: {{ section.settings.max_width }}px;"{% endif %}>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-10 lg:gap-16 items-center{% if enable_animation %} opacity-0 translate-y-8 transition-all duration-700 ease{% endif %}"
         data-inview="false"
         {% if section.settings.background_color != blank %}style="background-color: {{ section.settings.background_color }};"{% endif %}>

      {%- comment -%} Media {%- endcomment -%}
      <div class="relative bg-taupe-300 overflow-hidden {{ media_order_mobile }} {{ media_order_desktop }}">
        {%- if media_type == 'image' -%}
          {%- if section.settings.image != blank -%}
            <picture>
              {%- if section.settings.mobile_image != blank -%}
                <source
                  media="(max-width: 767px)"
                  srcset="{{ section.settings.mobile_image | image_url: width: 480 }} 480w,
                          {{ section.settings.mobile_image | image_url: width: 750 }} 750w"
                  sizes="100vw">
              {%- endif -%}
              <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                        {{ section.settings.image | image_url: width: 800 }} 800w,
                        {{ section.settings.image | image_url: width: 1260 }} 1260w"
                sizes="(min-width: 768px) 50vw, 100vw"
                alt="{{ section.settings.image.alt | escape | default: section.settings.title | escape }}"
                width="{{ section.settings.image.width }}"
                height="{{ section.settings.image.height }}"
                loading="lazy"
                class="block w-full h-auto">
            </picture>
          {%- endif -%}

        {%- elsif media_type == 'video' and section.settings.video_src != blank -%}
          <video
            class="block w-full h-auto"
            {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1200 }}"{% endif %}
            controls
            playsinline
            preload="metadata">
            <source src="{{ section.settings.video_src | escape }}">
          </video>

        {%- elsif media_type == 'embed' and embed_src != blank -%}
          <div class="relative aspect-video">
            <iframe
              src="{{ embed_src }}"
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
              loading="lazy"
              title="{{ section.settings.title | escape | default: 'Embedded video' }}"></iframe>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Copy {%- endcomment -%}
      <div class="flex flex-col justify-center px-4 md:px-0 {{ text_order_mobile }} {{ text_order_desktop }}"
           {% if section.settings.text_color != blank %}style="color: {{ section.settings.text_color }};"{% endif %}>
        {%- if section.settings.subtitle != blank -%}
          <p class="text-sm uppercase tracking-wider mb-3">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="font-serif text-3xl lg:text-4xl mb-4">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.copy != blank -%}
          <div class="rte mb-6 [&_p]:m-0 [&_p+p]:mt-4">
            {{ section.settings.copy }}
          </div>
        {%- endif -%}

        {%- if section.settings.btn_text != blank and section.settings.btn_link != blank -%}
          <div>
            <a href="{{ section.settings.btn_link }}" class="{{ btn_class }}">
              {{ section.settings.btn_text | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{%- if enable_animation -%}
  <script>
    (function () {
      var section = document.getElementById('media-text-{{ section.id }}');
      if (!section) return;
      var wrapper = section.querySelector('[data-inview]');
      if (!wrapper) return;
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.setAttribute('data-inview', 'true');
              entry.target.classList.remove('opacity-0', 'translate-y-8');
              entry.target.classList.add('opacity-100', 'translate-y-0');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -10%' }
      );
      observer.observe(wrapper);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Media Text",
  "tag": "section",
  "class": "media-text-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "media_first_desktop",
      "label": "Media first on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "media_first_mobile",
      "label": "Media first on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "radio",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "embed", "label": "Embed (YouTube / Vimeo)" },
        { "value": "video", "label": "Video (self-hosted URL)" }
      ],
      "default": "image"
    },
    {
      "type": "video_url",
      "id": "embed",
      "label": "Embed source",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "text",
      "id": "video_src",
      "label": "Video source URL",
      "info": "Direct link to an .mp4 or similar"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Also used as video poster"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "btn_style",
      "label": "Button style",
      "options": [
        { "value": "button--primary", "label": "Primary" },
        { "value": "button--primary button--inverse", "label": "Primary inverse" },
        { "value": "button--primary button--outlined", "label": "Primary outline" },
        { "value": "button--secondary", "label": "Secondary" },
        { "value": "button--secondary button--inverse", "label": "Secondary inverse" },
        { "value": "button--secondary button--outlined", "label": "Secondary outline" },
        { "value": "", "label": "None" }
      ],
      "default": "button--primary"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 300,
      "max": 1440,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll animation",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Media Text"
    }
  ]
}
{% endschema %}
