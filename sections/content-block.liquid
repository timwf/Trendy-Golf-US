{%- liquid
  assign alignment = section.settings.alignment
  assign bg_color = section.settings.background_color
  assign enable_animation = section.settings.enable_animation

  case alignment
    when 'left'
      assign alignment_class = 'text-left'
      assign justify_class = 'justify-start'
    when 'center'
      assign alignment_class = 'text-center'
      assign justify_class = 'justify-center'
    when 'right'
      assign alignment_class = 'text-right'
      assign justify_class = 'justify-end'
  endcase

  case bg_color
    when 'transparent'
      assign bg_class = 'bg-transparent'
    when 'white'
      assign bg_class = 'bg-white'
    when 'light-grey'
      assign bg_class = 'bg-taupe-100'
    when 'medium-grey'
      assign bg_class = 'bg-taupe-400'
    when 'dark-grey'
      assign bg_class = 'bg-taupe-900'
  endcase

  assign spacing_classes = ''

  if section.settings.margin_top_desktop != 'none'
    assign spacing_classes = spacing_classes | append: ' lg:mt-' | append: section.settings.margin_top_desktop
  endif
  if section.settings.margin_bottom_desktop != 'none'
    assign spacing_classes = spacing_classes | append: ' lg:mb-' | append: section.settings.margin_bottom_desktop
  endif
  if section.settings.padding_top_desktop != 'none'
    assign spacing_classes = spacing_classes | append: ' lg:pt-' | append: section.settings.padding_top_desktop
  endif
  if section.settings.padding_bottom_desktop != 'none'
    assign spacing_classes = spacing_classes | append: ' lg:pb-' | append: section.settings.padding_bottom_desktop
  endif
  if section.settings.margin_top_mobile != 'none'
    assign spacing_classes = spacing_classes | append: ' mt-' | append: section.settings.margin_top_mobile
  endif
  if section.settings.margin_bottom_mobile != 'none'
    assign spacing_classes = spacing_classes | append: ' mb-' | append: section.settings.margin_bottom_mobile
  endif
  if section.settings.padding_top_mobile != 'none'
    assign spacing_classes = spacing_classes | append: ' pt-' | append: section.settings.padding_top_mobile
  endif
  if section.settings.padding_bottom_mobile != 'none'
    assign spacing_classes = spacing_classes | append: ' pb-' | append: section.settings.padding_bottom_mobile
  endif

  assign has_button = false
  for block in section.blocks
    if block.type == 'button' and block.settings.label != blank
      assign has_button = true
      break
    endif
  endfor
-%}

<section class="page-block relative page-block--content{{ spacing_classes }} {{ bg_class }}{% unless enable_animation %} [&_.group-inview_.animation-group]:!translate-x-0 [&_.group-inview_.animation-group]:!translate-y-0 [&_.group-inview_.animation-group]:!scale-100 [&_.group-inview_.animation-group]:!opacity-100 [&_.group-inview_.animation-group]:!transition-none [&_.group-inview_.animation-group]:!duration-0{% endunless %}"
  data-content-block-section id="content-block-{{ section.id }}">
  <div data-inview="false" class="group-inview group/blocks">
    <div class="container-narrow {{ alignment_class }}">

      {%- comment -%} Content blocks (heading + text) — animateTranslateToBottom {%- endcomment -%}
      <div class="opacity-0 -translate-y-14 transition-all duration-1000 ease animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:translate-y-0">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'heading' -%}
              {%- liquid
                assign heading_tag = block.settings.tag
                assign heading_font = block.settings.font

                case block.settings.size
                  when 'h1'
                    assign size_class = 'text-5xl lg:text-6xl'
                  when 'h2'
                    assign size_class = 'text-4xl lg:text-5xl'
                  when 'h3'
                    assign size_class = 'text-3xl lg:text-4xl'
                  when 'h4'
                    assign size_class = 'text-xl lg:text-2xl'
                  when 'h5'
                    assign size_class = 'text-lg lg:text-xl'
                  when 'h6'
                    assign size_class = 'text-base lg:text-lg'
                endcase
              -%}
              <{{ heading_tag }} {{ block.shopify_attributes }}>
                {%- if heading_font == 'serif' -%}
                  <span class="font-serif"><span class="{{ size_class }}">{{ block.settings.text }}</span></span>
                {%- else -%}
                  <span class="{{ size_class }}">{{ block.settings.text }}</span>
                {%- endif -%}
              </{{ heading_tag }}>

            {%- when 'text' -%}
              <div class="rte" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Button blocks — animateTranslateToTop {%- endcomment -%}
      {%- if has_button -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' and block.settings.label != blank -%}
            {%- liquid
              case block.settings.style
                when 'dark-grey'
                  assign btn_style_class = 'bg-taupe-900 text-white enabled:hover:bg-taupe-600'
                when 'white'
                  assign btn_style_class = 'bg-white text-taupe-900 enabled:hover:bg-neutral-100'
                when 'transparent'
                  assign btn_style_class = 'bg-transparent transition-colors enabled:hover:bg-transparent enabled:hover:text-clubhouse-green-600'
                when 'text'
                  assign btn_style_class = ''
              endcase

              assign is_text_style = false
              if block.settings.style == 'text'
                assign is_text_style = true
              endif
            -%}
            <div class="flex opacity-0 translate-y-14 transition-all duration-1000 ease animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:translate-y-0 {{ justify_class }}"
                 {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link }}"
                 class="flex items-center gap-2 text-center text-sm tracking-wider transition-all disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 uppercase{% unless is_text_style %} justify-center px-4 py-3 lg:px-10 min-w-40{% endunless %} {{ btn_style_class }}">
                <span>{{ block.settings.label }}</span>
                {%- if block.settings.has_arrow -%}
                  {%- render 'icon', icon: 'chevron-right', size: 'size-4' -%}
                {%- endif -%}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('content-block-{{ section.id }}');
    if (!section) return;

    var enableAnimation = {{ enable_animation | json }};
    if (!enableAnimation) return;

    var wrapper = section.querySelector('[data-inview]');
    if (!wrapper) return;

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.setAttribute('data-inview', 'true');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3, rootMargin: '0px 0px -20%' }
    );
    observer.observe(wrapper);
  })();
</script>

