{%- if section.settings.text != blank -%}
  <div
    class="announcement-bar flex items-center justify-center px-4 py-2 text-center text-xs font-medium tracking-wide md:text-sm"
    style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
    role="region"
    aria-label="{{ 'sections.announcement_bar.label' | t }}"
  >
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="hover:underline">
        {{ section.settings.text }}
        {%- if section.settings.link_text != blank -%}
          <span class="ml-1 underline">{{ section.settings.link_text }}</span>
        {%- endif -%}
      </a>
    {%- else -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.announcement_bar.settings.text.label",
      "default": "Free UK delivery on orders over £150"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.announcement_bar.settings.link.label"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.announcement_bar.settings.link_text.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.announcement_bar.settings.background_color.label",
      "default": "#35342f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.announcement_bar.settings.text_color.label",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.name"
    }
  ]
}
{% endschema %}
