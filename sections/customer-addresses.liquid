{% comment %}
  Customer addresses — sidebar + main, with inline add/edit/delete/default.
  Source: _reference/repo/app/routes/account.addresses.tsx
{% endcomment %}

{%- liquid
  assign returns_base = section.settings.returns_url | default: 'https://returns.trendygolf.com'
  assign default_address = customer.default_address

  if default_address != blank
    assign other_count = customer.addresses_count | minus: 1
  else
    assign other_count = customer.addresses_count
  endif
-%}

<div class="container grid gap-5 py-10 lg:grid-cols-10 lg:gap-10" data-addresses-section>
  {% render 'account-sidebar',
    active: 'addresses',
    returns_url: returns_base
  %}

  <main class="col-span-1 lg:col-span-7 2xl:col-span-8">
    <div class="mb-6 inline-block lg:hidden">
      {% render 'form-button',
        label: 'Back',
        href: routes.account_url,
        style: 'text',
        icon: 'chevron-left',
        icon_size: 'size-4',
        min_width: false,
        uppercase: false,
        class: 'font-bold'
      %}
    </div>

    <h1 class="mb-8 text-xl font-bold lg:text-2xl">Address Book</h1>

    {%- if default_address != blank -%}
      <div class="bg-taupe-300 p-6 mb-6" data-address-row="{{ default_address.id }}">
        <h3 class="text-lg lg:text-xl">Default Address</h3>
        <p>This address will be used as the default for all future orders</p>
        <div class="flex justify-between gap-5 xl:gap-10">
          <div class="flex-1">
            <div data-address-view="{{ default_address.id }}">
              {% render 'address-item', address: default_address %}
            </div>
            <div data-address-edit="{{ default_address.id }}" hidden>
              {% render 'address-form',
                address: default_address,
                form_id: default_address.id
              %}
            </div>
          </div>
          <div class="flex flex-col gap-3 pt-6">
            <div>
              <button
                type="button"
                class="flex items-center gap-3 text-lg font-bold transition-colors hover:text-clubhouse-green-600"
                data-address-toggle="{{ default_address.id }}"
                aria-label="Toggle edit address"
              >
                <span data-address-toggle-view="{{ default_address.id }}">
                  {% render 'icon', icon: 'pencil', size: 'size-6' %}
                </span>
                <span data-address-toggle-view="{{ default_address.id }}">Edit</span>
                <span data-address-toggle-edit="{{ default_address.id }}" hidden>
                  {% render 'icon', icon: 'x-mark', size: 'size-6' %}
                </span>
                <span data-address-toggle-edit="{{ default_address.id }}" hidden>Cancel</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    {%- else -%}
      <p class="mb-6">You have no addresses saved</p>
    {%- endif -%}

    <div class="mb-6 inline-block">
      <button
        type="button"
        data-add-address-toggle
        class="flex items-center gap-2 bg-taupe-900 px-4 py-3 text-center text-sm uppercase tracking-wider text-white transition-all enabled:hover:bg-taupe-600 lg:px-10"
      >
        <span>Add new address</span>
      </button>
    </div>

    <div class="mb-6 bg-taupe-300 p-6" data-add-address-panel hidden>
      <h3 class="mb-4 text-lg lg:text-xl">Add new address</h3>
      {% render 'address-form',
        address: customer.new_address,
        is_new: true,
        form_id: 'new_address'
      %}
    </div>

    {%- if other_count > 0 -%}
      <div class="bg-taupe-300 p-6 mb-6">
        <h3 class="font-sans text-base font-bold lg:text-lg">Other Addresses</h3>
        <div class="flex flex-col gap-5">
          {%- assign processed = 0 -%}
          {%- for address in customer.addresses -%}
            {%- if default_address != blank and address.id == default_address.id -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign processed = processed | plus: 1 -%}
            <div{% if processed < other_count %} class="border-b border-taupe-400 pb-3"{% endif %} data-address-row="{{ address.id }}">
              <div class="mb-3 flex justify-between gap-5 xl:gap-10">
                <div class="flex-1">
                  <div data-address-view="{{ address.id }}">
                    {% render 'address-item', address: address %}
                  </div>
                  <div data-address-edit="{{ address.id }}" hidden>
                    {% render 'address-form',
                      address: address,
                      form_id: address.id
                    %}
                  </div>
                </div>
                <div class="flex flex-col items-end gap-5 pt-6">
                  <div>
                    {%- form 'customer_address', address -%}
                      <input type="hidden" name="address[default]" value="1">
                      <button
                        type="submit"
                        class="flex items-center gap-3 text-lg font-bold transition-colors hover:text-clubhouse-green-600"
                      >
                        {% render 'icon', icon: 'star', size: 'size-6' %}
                        <span>Set as default</span>
                      </button>
                    {%- endform -%}
                  </div>
                  <div>
                    <button
                      type="button"
                      class="flex items-center gap-3 text-lg font-bold transition-colors hover:text-clubhouse-green-600"
                      data-address-toggle="{{ address.id }}"
                      aria-label="Toggle edit address"
                    >
                      <span data-address-toggle-view="{{ address.id }}">
                        {% render 'icon', icon: 'pencil', size: 'size-6' %}
                      </span>
                      <span data-address-toggle-view="{{ address.id }}">Edit</span>
                      <span data-address-toggle-edit="{{ address.id }}" hidden>
                        {% render 'icon', icon: 'x-mark', size: 'size-6' %}
                      </span>
                      <span data-address-toggle-edit="{{ address.id }}" hidden>Cancel</span>
                    </button>
                  </div>
                  <div>
                    {%- form 'customer_address', address -%}
                      <input type="hidden" name="_method" value="delete">
                      <button
                        type="submit"
                        class="flex items-center gap-3 text-lg font-bold transition-colors hover:text-clubhouse-green-600"
                      >
                        {% render 'icon', icon: 'trash', size: 'size-6' %}
                        <span>Delete</span>
                      </button>
                    {%- endform -%}
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </main>
</div>

<script>
  (function () {
    const section = document.querySelector('[data-addresses-section]');
    if (!section) return;

    const toggleAll = (selector) => {
      section.querySelectorAll(selector).forEach((el) => {
        el.hidden = !el.hidden;
      });
    };

    // Edit ↔ view toggle per address
    section.querySelectorAll('[data-address-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-address-toggle');
        toggleAll(
          `[data-address-view="${id}"], [data-address-edit="${id}"], [data-address-toggle-view="${id}"], [data-address-toggle-edit="${id}"]`
        );
      });
    });

    // Add new address panel
    const addToggle = section.querySelector('[data-add-address-toggle]');
    const addPanel = section.querySelector('[data-add-address-panel]');
    if (addToggle && addPanel) {
      addToggle.addEventListener('click', () => {
        addPanel.hidden = !addPanel.hidden;
        if (!addPanel.hidden) {
          addPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
      if (addPanel.querySelector('.bg-red-100')) {
        addPanel.hidden = false;
      }
    }

    // Country → province dependency
    section.querySelectorAll('[data-address-country]').forEach((countrySelect) => {
      const formId = countrySelect.getAttribute('data-address-form');
      const provinceSelect = section.querySelector(`[data-address-province="${formId}"]`);
      const provinceWrapper = section.querySelector(`[data-address-province-wrapper="${formId}"]`);
      if (!provinceSelect || !provinceWrapper) return;

      const syncProvinces = () => {
        const opt = countrySelect.selectedOptions[0];
        const raw = opt && opt.getAttribute('data-provinces');
        let provinces = [];
        try {
          provinces = raw ? JSON.parse(raw) : [];
        } catch (e) {
          provinces = [];
        }
        if (!provinces.length) {
          provinceSelect.innerHTML = '';
          provinceWrapper.hidden = true;
          return;
        }
        provinceWrapper.hidden = false;
        const desired = provinceSelect.getAttribute('data-default') || '';
        provinceSelect.innerHTML = provinces
          .map(
            (p) =>
              `<option value="${p[0]}"${p[0] === desired ? ' selected' : ''}>${p[1]}</option>`
          )
          .join('');
      };

      countrySelect.addEventListener('change', () => {
        provinceSelect.setAttribute('data-default', '');
        syncProvinces();
      });
      syncProvinces();
    });

    // Auto-open an address edit panel if its form has errors
    section.querySelectorAll('[data-address-edit]').forEach((panel) => {
      if (panel.querySelector('.bg-red-100')) {
        const id = panel.getAttribute('data-address-edit');
        toggleAll(
          `[data-address-view="${id}"], [data-address-edit="${id}"], [data-address-toggle-view="${id}"], [data-address-toggle-edit="${id}"]`
        );
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Customer addresses",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "url",
      "id": "returns_url",
      "label": "Returns portal URL",
      "info": "External returns portal. Defaults to https://returns.trendygolf.com when blank."
    }
  ]
}
{% endschema %}
