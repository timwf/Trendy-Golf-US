{%- liquid
  assign desktop_columns_class = 'xl:grid-cols-4'
  if section.settings.desktop_columns == 'three'
    assign desktop_columns_class = 'xl:grid-cols-3'
  endif

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'lg:mb-14 mb-8'
    when 'large'
      assign margin_class = 'lg:mb-20 mb-14'
  endcase

  assign enable_animation = section.settings.enable_animation
  assign initial_inview = 'false'
  unless enable_animation
    assign initial_inview = 'true'
  endunless
-%}

<section
  id="icon-grid-{{ section.id }}"
  class="page-block relative page-block--iconGrid {{ margin_class }} bg-transparent"
>
  <div
    data-inview="{{ initial_inview }}"
    class="group-inview group/blocks container-wide grid grid-cols-1 border-l border-t border-taupe-600 px-0 md:grid-cols-2 {{ desktop_columns_class }}"
  >
    {%- for block in section.blocks -%}
      {%- assign delay = forloop.index0 | times: 90 -%}
      <div
        style="transition-delay:calc(var(--base-delay, 0ms) + {{ delay }}ms)"
        class="border-b border-r border-taupe-600 px-8 py-6 md:p-14 opacity-0 transition-opacity duration-1000 animation-group group-data-[inview=true]/blocks:opacity-100"
        {{ block.shopify_attributes }}
      >
        <div class="flex flex-row gap-6 md:max-w-96 md:flex-col md:gap-0">
          {%- if block.settings.icon_image != blank -%}
            <div class="mb-5">
              {{
                block.settings.icon_image
                | image_url: width: 64
                | image_tag:
                  class: 'size-8 object-contain',
                  loading: 'lazy',
                  widths: '32,64,96,128',
                  alt: block.settings.title | default: ''
              }}
            </div>
          {%- elsif block.settings.icon != 'none' -%}
            <div class="mb-5">
              {% render 'icon', icon: block.settings.icon, size: 'size-8' %}
            </div>
          {%- endif -%}
          <div class="flex flex-col md:flex-1">
            {%- if block.settings.title != blank -%}
              <div class="mb-3">
                <h4 class="mb-0 font-bold text-lg lg:text-xl">{{ block.settings.title }}</h4>
              </div>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="whitespace-pre-line">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.show_social_channels -%}
              <div class="mt-2">
                {% render 'social-links' %}
              </div>
            {%- endif -%}
            {%- if block.settings.link_label != blank and block.settings.link != blank -%}
              <div class="mt-auto">
                <a
                  class="flex items-center gap-2 text-center text-sm tracking-wider transition-all disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 font-bold"
                  href="{{ block.settings.link }}"
                >
                  <span>{{ block.settings.link_label }}</span>
                  {%- if block.settings.show_arrow -%}
                    {% render 'icon', icon: 'chevron-right', size: 'size-4' %}
                  {%- endif -%}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{%- if enable_animation -%}
  <script>
    (function () {
      var section = document.getElementById('icon-grid-{{ section.id }}');
      if (!section) return;
      var wrapper = section.querySelector('[data-inview]');
      if (!wrapper) return;

      if (!('IntersectionObserver' in window)) {
        wrapper.setAttribute('data-inview', 'true');
        return;
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.setAttribute('data-inview', 'true');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -10%' }
      );
      observer.observe(wrapper);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.icon_grid.name",
  "tag": "section",
  "class": "page-block--iconGrid",
  "settings": [
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "t:sections.icon_grid.settings.desktop_columns.label",
      "options": [
        { "value": "three", "label": "t:sections.icon_grid.settings.desktop_columns.options.three" },
        { "value": "four", "label": "t:sections.icon_grid.settings.desktop_columns.options.four" }
      ],
      "default": "four"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "t:sections.icon_grid.settings.margin_bottom.label",
      "options": [
        { "value": "none", "label": "t:sections.icon_grid.settings.margin_bottom.options.none" },
        { "value": "small", "label": "t:sections.icon_grid.settings.margin_bottom.options.small" },
        { "value": "medium", "label": "t:sections.icon_grid.settings.margin_bottom.options.medium" },
        { "value": "large", "label": "t:sections.icon_grid.settings.margin_bottom.options.large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.icon_grid.settings.enable_animation.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.icon_grid.blocks.column.name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.icon_grid.blocks.column.settings.icon.label",
          "options": [
            { "value": "none", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.none" },
            { "value": "truck", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.truck" },
            { "value": "arrow-uturn-left", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.uturn" },
            { "value": "user-group", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.user_group" },
            { "value": "trophy", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.trophy" },
            { "value": "envelope", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.envelope" },
            { "value": "phone", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.phone" },
            { "value": "device-phone-mobile", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.device_phone_mobile" },
            { "value": "map-pin", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.map_pin" },
            { "value": "clock", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.clock" },
            { "value": "star", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.star" },
            { "value": "heart", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.heart" },
            { "value": "book-open", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.book_open" },
            { "value": "number-01", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.number_01" },
            { "value": "number-02", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.number_02" },
            { "value": "number-03", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.number_03" },
            { "value": "apparel", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.apparel" },
            { "value": "branding", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.branding" },
            { "value": "design", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.design" },
            { "value": "delivery", "label": "t:sections.icon_grid.blocks.column.settings.icon.options.delivery" }
          ],
          "default": "truck"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "t:sections.icon_grid.blocks.column.settings.icon_image.label",
          "info": "t:sections.icon_grid.blocks.column.settings.icon_image.info"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.icon_grid.blocks.column.settings.title.label",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.icon_grid.blocks.column.settings.description.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.icon_grid.blocks.column.settings.link.label"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "t:sections.icon_grid.blocks.column.settings.link_label.label",
          "default": "Learn More"
        },
        {
          "type": "checkbox",
          "id": "show_arrow",
          "label": "t:sections.icon_grid.blocks.column.settings.show_arrow.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_social_channels",
          "label": "t:sections.icon_grid.blocks.column.settings.show_social_channels.label",
          "info": "t:sections.icon_grid.blocks.column.settings.show_social_channels.info",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.icon_grid.presets.name",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
