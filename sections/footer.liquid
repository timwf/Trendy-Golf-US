<footer class="bg-taupe-300 py-10" role="contentinfo">
  <div class="container mb-14">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 xl:grid-cols-4">

      {%- comment -%} Contact column {%- endcomment -%}
      <div class="text-center">
        <h3 class="font-bold">{{ 'sections.footer.contact_heading' | t }}</h3>
        <ul class="flex flex-col gap-1.5">
          {%- if section.settings.email != blank -%}
            <li>
              <a href="mailto:{{ section.settings.email }}" class="text-sm hover:underline">
                {{ section.settings.email }}
              </a>
            </li>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            <li>
              <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' }}" class="text-sm hover:underline">
                {{ section.settings.phone }}
              </a>
            </li>
          {%- endif -%}

          <li>
            {% render 'social-links', class: 'justify-center' %}
          </li>
        </ul>
      </div>

      {%- comment -%} Navigation columns {%- endcomment -%}
      {%- if section.settings.menu_1 != blank -%}
        <div class="text-center">
          <h3 class="font-bold">
            {%- if section.settings.menu_1_heading != blank -%}
              {{ section.settings.menu_1_heading }}
            {%- else -%}
              {{ section.settings.menu_1.title }}
            {%- endif -%}
          </h3>
          <nav aria-label="{{ section.settings.menu_1.title }}">
            <ul class="flex flex-col gap-1.5">
              {%- for link in section.settings.menu_1.links -%}
                <li>
                  <a href="{{ link.url }}" class="hover:underline">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        </div>
      {%- endif -%}

      {%- if section.settings.menu_2 != blank -%}
        <div class="text-center">
          <h3 class="font-bold">
            {%- if section.settings.menu_2_heading != blank -%}
              {{ section.settings.menu_2_heading }}
            {%- else -%}
              {{ section.settings.menu_2.title }}
            {%- endif -%}
          </h3>
          <nav aria-label="{{ section.settings.menu_2.title }}">
            <ul class="flex flex-col gap-1.5">
              {%- for link in section.settings.menu_2.links -%}
                <li>
                  <a href="{{ link.url }}" class="hover:underline">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        </div>
      {%- endif -%}

      {%- if section.settings.menu_3 != blank -%}
        <div class="text-center">
          <h3 class="font-bold">
            {%- if section.settings.menu_3_heading != blank -%}
              {{ section.settings.menu_3_heading }}
            {%- else -%}
              {{ section.settings.menu_3.title }}
            {%- endif -%}
          </h3>
          <nav aria-label="{{ section.settings.menu_3.title }}">
            <ul class="flex flex-col gap-1.5">
              {%- for link in section.settings.menu_3.links -%}
                <li>
                  <a href="{{ link.url }}" class="hover:underline">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} Brand wordmark {%- endcomment -%}
  {%- if section.settings.show_logo -%}
    <div class="container-wide mb-14">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1465 159" fill="none" aria-label="{{ shop.name }}">
        <g clip-path="url(#footer-logo-clip)">
