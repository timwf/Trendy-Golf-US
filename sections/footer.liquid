        </g>
        <defs>
          <clipPath id="footer-logo-clip">
            <rect width="1464" height="158" fill="white" transform="translate(0.5 0.399902)"/>
          </clipPath>
        </defs>
      </svg>
    </div>
  {%- endif -%}

  {%- comment -%} Legal / copyright bar {%- endcomment -%}
  <div class="container">
    {%- if section.settings.menu_legal != blank -%}
      <nav class="mb-10" aria-label="{{ 'sections.footer.legal_nav' | t }}">
        <ul class="flex flex-col gap-1.5 text-center md:flex-row md:items-center md:justify-center md:gap-8">
          <li class="text-sm">
            {%- if section.settings.copyright_text != blank -%}
              {{ section.settings.copyright_text }}
            {%- else -%}
              &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
            {%- endif -%}
          </li>

          {%- for link in section.settings.menu_legal.links -%}
            <li>
              <a href="{{ link.url }}" class="hover:underline">{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- comment -%} Payment icons {%- endcomment -%}
    {%- if section.settings.show_payment_icons -%}
      {%- unless shop.enabled_payment_types == empty -%}
        <ul class="flex flex-wrap items-center justify-center gap-2" role="list" aria-label="{{ 'sections.footer.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag }}</li>
          {%- endfor -%}
        </ul>
      {%- endunless -%}
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.contact_heading.content"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.footer.settings.email.label",
      "default": "info@trendygolf.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.footer.settings.phone.label",
      "default": "+44 (0)1243 373251"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.navigation_heading.content"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "t:sections.footer.settings.menu_1.label",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "t:sections.footer.settings.menu_1_heading.label",
      "info": "t:sections.footer.settings.menu_heading_info.info"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "t:sections.footer.settings.menu_2.label"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "t:sections.footer.settings.menu_2_heading.label",
      "info": "t:sections.footer.settings.menu_heading_info.info"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "t:sections.footer.settings.menu_3.label"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "t:sections.footer.settings.menu_3_heading.label",
      "info": "t:sections.footer.settings.menu_heading_info.info"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.bottom_heading.content"
    },
    {
      "type": "link_list",
      "id": "menu_legal",
      "label": "t:sections.footer.settings.menu_legal.label"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:sections.footer.settings.copyright_text.label",
      "info": "t:sections.footer.settings.copyright_text.info"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "t:sections.footer.settings.show_logo.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    }
  ]
}
{% endschema %}
