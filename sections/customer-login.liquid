{% comment %}
  Customer login page — two-column layout over a full-bleed background image.
  Left:  rewards marketing panel (schema-editable)
  Right: login form + inline "forgot password" toggle
{% endcomment %}

<div class="relative py-20 md:flex md:min-h-[80dvh] md:flex-col md:justify-center">
  <div class="container relative z-1 flex flex-col items-center">
    <div class="grid max-w-5xl md:grid-cols-2">

      {%- comment -%} Left: Rewards marketing panel {%- endcomment -%}
      <div class="flex flex-col bg-clubhouse-green-600 p-8 md:p-10 md:px-14">
        <div class="mb-4">
          {%- if section.settings.rewards_logo != blank -%}
            <img
              src="{{ section.settings.rewards_logo | image_url: width: 288 }}"
              alt="{{ section.settings.rewards_logo.alt | default: shop.name }}"
              width="144"
              height="{{ 144 | divided_by: section.settings.rewards_logo.aspect_ratio | round }}"
              class="mb-5 hidden md:inline-block"
              loading="eager"
            >
          {%- endif -%}

          {%- if section.settings.rewards_heading != blank -%}
            <p class="mb-0 text-xl font-bold text-white md:text-base md:font-normal">
              {{ section.settings.rewards_heading }}
            </p>
          {%- endif -%}
        </div>

        {%- assign bullet_blocks = section.blocks | where: 'type', 'bullet' -%}
        {%- if bullet_blocks.size > 0 -%}
          <div class="text-white">
            <div class="grid gap-5">
              {%- for block in bullet_blocks -%}
                <div class="flex gap-4" {{ block.shopify_attributes }}>
                  <div class="w-8 opacity-80">
                    {%- if block.settings.icon != blank -%}
                      {% render 'icon', icon: block.settings.icon, size: 'size-8' %}
                    {%- endif -%}
                  </div>
                  <div class="flex items-center [&_*]:mb-0">
                    {{ block.settings.text }}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: Form panel {%- endcomment -%}
      <div class="bg-taupe-300 px-8 py-10 md:px-14">
        {%- if section.settings.account_content != blank -%}
          <div class="mb-5 text-center">
            {{ section.settings.account_content }}
          </div>
        {%- endif -%}

        <h1 class="mb-6 text-center font-serif text-3xl lg:text-4xl">Sign in</h1>

        {%- if section.settings.promo_banner != blank -%}
          <div class="mb-6 flex flex-col gap-2">
            <div class="flex items-center gap-2 border border-clubhouse-green-600 bg-clubhouse-green-200 px-4 pt-4 text-sm [&_p]:mb-4">
              {% render 'icon', icon: 'trophy', size: 'size-5', class: 'mb-4 min-w-5 shrink-0' %}
              {{ section.settings.promo_banner }}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Login form (default view) {%- endcomment -%}
        <div id="customer-login-panel" data-login-panel>
          {%- form 'customer_login', novalidate: 'novalidate' -%}
            {%- if form.errors -%}
              <div class="mb-4 border border-red-600 bg-red-100 p-3 text-sm text-red-700">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="mb-4">
              {% render 'form-input',
                name: 'customer[email]',
                label: 'Email',
                type: 'email',
                placeholder: 'Enter your email',
                required: true,
                autocomplete: 'email',
                autofocus: true
              %}
            </div>

            <div class="mb-4">
              {% render 'form-input',
                name: 'customer[password]',
                label: 'Password',
                type: 'password',
                placeholder: 'Enter your password',
                required: true,
                autocomplete: 'current-password'
              %}
            </div>

            <div class="mb-4">
              <button type="button" data-recover-toggle class="text-sm tracking-wider underline transition-colors hover:text-clubhouse-green-600">
                Forgot your password?
              </button>
            </div>

            <div class="mb-4 flex w-full justify-center">
              {% render 'form-button', label: 'Sign in', type: 'submit', full_width: true %}
            </div>

            <p class="mb-0 text-center text-sm">
              Don't have an account?
              <a href="{{ routes.account_register_url }}" class="underline hover:text-clubhouse-green-600">Create one</a>
            </p>
          {%- endform -%}
        </div>

        {%- comment -%} Recover password (hidden by default) {%- endcomment -%}
        {%- assign show_recover = false -%}
        <div id="recover-password-panel" class="hidden" data-recover-panel>
          <h2 class="mb-4 text-xl font-bold lg:text-2xl">Reset your password</h2>
          <p class="mb-6 text-sm">We'll send you an email to reset your password.</p>

          {%- form 'recover_customer_password' -%}
            {%- if form.posted_successfully? -%}
              {%- assign show_recover = true -%}
              <div class="mb-4 border border-clubhouse-green-600 bg-clubhouse-green-200 p-3 text-sm">
                We've sent you an email with a link to reset your password.
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              {%- assign show_recover = true -%}
              <div class="mb-4 border border-red-600 bg-red-100 p-3 text-sm text-red-700">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="mb-4">
              {% render 'form-input',
                name: 'email',
                label: 'Email',
                type: 'email',
                placeholder: 'Enter your email',
                required: true,
                autocomplete: 'email'
              %}
            </div>

            <div class="mb-4 flex w-full justify-center">
              {% render 'form-button', label: 'Submit', type: 'submit', full_width: true %}
            </div>

            <div class="flex justify-center">
              <button type="button" data-recover-cancel class="text-sm tracking-wider underline transition-colors hover:text-clubhouse-green-600">
                Cancel
              </button>
            </div>
          {%- endform -%}
        </div>

      </div>
    </div>
  </div>

  {%- if section.settings.background_image != blank -%}
    <img
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      alt="{{ section.settings.background_image.alt | default: '' }}"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
      class="absolute left-0 top-0 size-full object-cover"
      loading="eager"
    >
  {%- endif -%}
</div>

<script>
  (function () {
    var loginPanel   = document.querySelector('[data-login-panel]');
    var recoverPanel = document.querySelector('[data-recover-panel]');
    var openRecover  = document.querySelector('[data-recover-toggle]');
    var closeRecover = document.querySelector('[data-recover-cancel]');
    if (!loginPanel || !recoverPanel) return;

    function show(panel) {
      loginPanel.classList.toggle('hidden', panel === 'recover');
      recoverPanel.classList.toggle('hidden', panel !== 'recover');
    }

    if (openRecover)  openRecover.addEventListener('click', function () { show('recover'); });
    if (closeRecover) closeRecover.addEventListener('click', function () { show('login'); });

    if (window.location.hash === '#recover') show('recover');
    {%- if show_recover -%}show('recover');{%- endif -%}
  })();
</script>

{% schema %}
{
  "name": "Customer login",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Full-bleed background image"
    },
    {
      "type": "header",
      "content": "Rewards marketing panel (left)"
    },
    {
      "type": "image_picker",
      "id": "rewards_logo",
      "label": "Logo (hidden on mobile)"
    },
    {
      "type": "text",
      "id": "rewards_heading",
      "label": "Heading",
      "default": "Register now and begin your journey with TRENDYGOLF Country Club."
    },
    {
      "type": "header",
      "content": "Form panel (right)"
    },
    {
      "type": "richtext",
      "id": "account_content",
      "label": "Intro text (optional)"
    },
    {
      "type": "richtext",
      "id": "promo_banner",
      "label": "Promo banner (optional)",
      "info": "Displays with a trophy icon in a green bordered box above the form.",
      "default": "<p>Hurry, new customers are currently receiving <strong>exclusive benefits & rewards</strong> points!</p>"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Rewards bullet",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gift", "label": "Gift" },
            { "value": "chart-bar-square", "label": "Tier" },
            { "value": "star", "label": "Star" },
            { "value": "trophy", "label": "Trophy" },
            { "value": "heart", "label": "Heart" },
            { "value": "truck", "label": "Truck" },
            { "value": "check-circle", "label": "Check circle" },
            { "value": "user", "label": "User" },
            { "value": "user-group", "label": "User group" }
          ],
          "default": "gift"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Bullet text",
          "default": "<p>Access to <strong>exclusive benefits & rewards</strong></p>"
        }
      ]
    }
  ]
}
{% endschema %}
