{%- liquid
  assign layout = section.settings.layout
  assign columns = section.settings.columns
  assign enable_animation = section.settings.enable_animation

  case section.settings.aspect_ratio
    when 'square'
      assign aspect_class = 'aspect-square'
    when '7:9'
      assign aspect_class = 'aspect-[7/9]'
    when '3:4'
      assign aspect_class = 'aspect-[3/4]'
  endcase

  case section.settings.heading_size
    when 'large'
      assign heading_size_class = 'text-3xl lg:text-4xl'
    when 'small'
      assign heading_size_class = 'text-xl lg:text-2xl'
  endcase

  assign heading_tag = section.settings.heading_tag

  case columns
    when 2
      assign grid_class = 'md:grid-cols-2'
      assign grid_sizes = '(min-width: 768px) 50vw, 100vw'
    when 3
      assign grid_class = 'md:grid-cols-3'
      assign grid_sizes = '(min-width: 768px) 33vw, 100vw'
    when 4
      assign grid_class = 'md:grid-cols-4'
      assign grid_sizes = '(min-width: 768px) 25vw, 100vw'
  endcase

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'mb-8 lg:mb-14'
    when 'large'
      assign margin_class = 'mb-14 lg:mb-20'
  endcase
-%}

<section class="banner-cards-section relative {{ margin_class }} overflow-hidden" data-banner-cards-section id="banner-cards-{{ section.id }}">
  <div class="container-wide">
    {%- if layout == 'grid' -%}
      <div class="grid grid-cols-1 gap-5 {{ grid_class }}">
        {%- for block in section.blocks -%}
          {%- render 'banner-card',
            block: block,
            aspect_class: aspect_class,
            heading_tag: heading_tag,
            heading_size_class: heading_size_class,
            enable_animation: enable_animation,
            loading: forloop.index,
            sizes: grid_sizes
          -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      <div class="splide" data-banner-carousel>
        <div class="splide__track overflow-visible xl:overflow-hidden xl:py-1">
          <ul class="splide__list">
            {%- for block in section.blocks -%}
              <li class="splide__slide">
                <div data-measure class="inline-block w-full h-full">
                  {%- render 'banner-card',
                    block: block,
                    aspect_class: aspect_class,
                    heading_tag: heading_tag,
                    heading_size_class: heading_size_class,
                    enable_animation: enable_animation,
                    loading: forloop.index,
                    sizes: '(min-width: 1280px) 25vw, (min-width: 768px) 33vw, 50vw'
                  -%}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('banner-cards-{{ section.id }}');
    if (!section) return;

    var enableAnimation = {{ enable_animation | json }};
    var layout = {{ layout | json }};
    var columns = {{ columns | json }};

    /* Intersection observer — per-card data-inview */
    if (enableAnimation) {
      var cards = section.querySelectorAll('[data-inview]');
      if (cards.length) {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-inview', 'true');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.3, rootMargin: '0px 0px -20%' }
        );
        cards.forEach(function (card) {
          observer.observe(card);
        });
      }
    }

    /* Splide init — carousel mode only */
    if (layout === 'carousel') {
      var el = section.querySelector('[data-banner-carousel]');
      if (el && typeof Splide !== 'undefined') {
        new Splide(el, {
          type: 'slide',
          perPage: columns,
          gap: '1.25rem',
          pagination: false,
          arrows: false,
          drag: true,
          breakpoints: {
            480: { perPage: 1, padding: { left: 0, right: '15%' } },
            768: { perPage: 2, padding: { left: 0, right: '10%' } },
            1280: { perPage: 2, padding: { left: 0, right: '15%' } }
          }
        }).mount();
      }
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.banner_cards.name",
  "tag": "section",
  "class": "banner-cards-section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.banner_cards.settings.layout.label",
      "options": [
        { "value": "grid", "label": "t:sections.banner_cards.settings.layout.options.grid" },
        { "value": "carousel", "label": "t:sections.banner_cards.settings.layout.options.carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.banner_cards.settings.columns.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:sections.banner_cards.settings.aspect_ratio.label",
      "options": [
        { "value": "square", "label": "t:sections.banner_cards.settings.aspect_ratio.options.square" },
        { "value": "7:9", "label": "t:sections.banner_cards.settings.aspect_ratio.options.7_9" },
        { "value": "3:4", "label": "t:sections.banner_cards.settings.aspect_ratio.options.3_4" }
      ],
      "default": "square"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.banner_cards.settings.heading_tag.label",
      "options": [
        { "value": "h2", "label": "t:sections.banner_cards.settings.heading_tag.options.h2" },
        { "value": "h3", "label": "t:sections.banner_cards.settings.heading_tag.options.h3" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.banner_cards.settings.heading_size.label",
      "options": [
        { "value": "large", "label": "t:sections.banner_cards.settings.heading_size.options.large" },
        { "value": "small", "label": "t:sections.banner_cards.settings.heading_size.options.small" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "t:sections.banner_cards.settings.margin_bottom.label",
      "options": [
        { "value": "none", "label": "t:sections.banner_cards.settings.margin_bottom.options.none" },
        { "value": "small", "label": "t:sections.banner_cards.settings.margin_bottom.options.small" },
        { "value": "medium", "label": "t:sections.banner_cards.settings.margin_bottom.options.medium" },
        { "value": "large", "label": "t:sections.banner_cards.settings.margin_bottom.options.large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.banner_cards.settings.enable_animation.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.banner_cards.blocks.card.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.banner_cards.blocks.card.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.banner_cards.blocks.card.settings.image.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.banner_cards.blocks.card.settings.link.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.banner_cards.blocks.card.settings.button_label.label",
          "default": "SHOP NOW"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.banner_cards.presets.name",
      "blocks": [
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
