{%- comment -%} Content columns — 3-col grid on desktop, carousel on mobile {%- endcomment -%}
{%- liquid
  assign enable_animation = section.settings.enable_animation
  assign initial_inview = 'false'
  unless enable_animation
    assign initial_inview = 'true'
  endunless

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'lg:mb-14 mb-8'
    when 'large'
      assign margin_class = 'lg:mb-20 mb-14'
  endcase
-%}

<section
  id="content-columns-{{ section.id }}"
  class="page-block relative page-block--contentColumns {{ margin_class }} bg-transparent"
>
  {%- if section.settings.heading != blank -%}
    <div
      data-inview="{{ initial_inview }}"
      class="group-inview group/blocks"
    >
      <div class="container mb-8 text-center lg:mb-10 opacity-0 -translate-y-14 transition-all duration-1000 ease animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:translate-y-0">
        <h2>
          <span class="font-serif">
            <span class="text-3xl lg:text-4xl">{{ section.settings.heading }}</span>
          </span>
        </h2>
      </div>
    </div>
  {%- endif -%}

  <div class="container-narrow">
    <div class="hidden grid-cols-3 gap-5 lg:grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign delay_class = ''
          assign mod = forloop.index | modulo: 3
          if mod == 2
            assign delay_class = ' md:delay-100'
          elsif mod == 0
            assign delay_class = ' md:delay-200'
          endif
        -%}
        <div
          data-inview="{{ initial_inview }}"
          class="group-inview group/blocks"
          {{ block.shopify_attributes }}
        >
          <div class="opacity-0 scale-75 transition-all duration-1000 animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:scale-100{{ delay_class }}">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1100
                | image_tag:
                  class: 'relative mb-6 aspect-[7/9] object-cover',
                  loading: 'lazy',
                  widths: '320,480,640,800,1100',
                  sizes: '(min-width: 1024px) 33vw, 100vw',
                  alt: block.settings.image_alt | default: block.settings.title
              }}
            {%- endif -%}
            {%- if block.settings.title != blank or block.settings.description != blank -%}
              <div class="text-center">
                {%- if block.settings.title != blank -%}
                  <h4 class="mb-3 font-bold text-lg lg:text-xl">{{ block.settings.title }}</h4>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p>{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div
      data-inview="{{ initial_inview }}"
      class="group-inview group/blocks block lg:hidden"
    >
      <div class="relative" data-pagination-hide="false" data-pagination-dark="false">
        <div class="splide relative" data-content-columns-carousel>
          <div class="splide__track">
            <ul class="splide__list">
              {%- for block in section.blocks -%}
                {%- assign delay = forloop.index0 | times: 90 -%}
                <li class="splide__slide">
                  <div data-measure="true" class="inline-block w-full h-full">
                    <div
                      style="transition-delay:calc(var(--base-delay, 0ms) + {{ delay }}ms)"
                      class="opacity-0 scale-75 transition-all duration-1000 animation-group group-data-[inview=true]/blocks:opacity-100 group-data-[inview=true]/blocks:scale-100"
                      {{ block.shopify_attributes }}
                    >
                      {%- if block.settings.image != blank -%}
                        {{
                          block.settings.image
                          | image_url: width: 1100
                          | image_tag:
                            class: 'relative mb-6 aspect-[7/9] object-cover',
                            loading: 'lazy',
                            widths: '320,480,640,800,1100',
                            sizes: '(max-width: 480px) 80vw, (max-width: 1024px) 45vw, 33vw',
                            alt: block.settings.image_alt | default: block.settings.title
                        }}
                      {%- endif -%}
                      {%- if block.settings.title != blank or block.settings.description != blank -%}
                        <div class="text-center">
                          {%- if block.settings.title != blank -%}
                            <h4 class="mb-3 font-bold text-lg lg:text-xl">{{ block.settings.title }}</h4>
                          {%- endif -%}
                          {%- if block.settings.description != blank -%}
                            <p>{{ block.settings.description }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('content-columns-{{ section.id }}');
    if (!section) return;

    var enableAnimation = {{ enable_animation | json }};

    if (enableAnimation && 'IntersectionObserver' in window) {
      var wrappers = section.querySelectorAll('[data-inview]');
      if (wrappers.length) {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-inview', 'true');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -10%' }
        );
        wrappers.forEach(function (w) { observer.observe(w); });
      }
    }

    var el = section.querySelector('[data-content-columns-carousel]');
    if (el && typeof Splide !== 'undefined') {
      new Splide(el, {
        type: 'slide',
        perPage: 3,
        gap: '1.25rem',
        arrows: false,
        pagination: false,
        drag: true,
        mediaQuery: 'max',
        breakpoints: {
          480: { perPage: 1, padding: { left: 0, right: '20%' } },
          768: { perPage: 2, padding: { left: 0, right: '15%' } },
          1280: { perPage: 2, padding: { left: 0, right: '20%' } }
        }
      }).mount();
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.content_columns.name",
  "tag": "section",
  "class": "page-block--contentColumns",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.content_columns.settings.heading.label",
      "default": "What we offer"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "t:sections.content_columns.settings.margin_bottom.label",
      "options": [
        { "value": "none", "label": "t:sections.content_columns.settings.margin_bottom.options.none" },
        { "value": "small", "label": "t:sections.content_columns.settings.margin_bottom.options.small" },
        { "value": "medium", "label": "t:sections.content_columns.settings.margin_bottom.options.medium" },
        { "value": "large", "label": "t:sections.content_columns.settings.margin_bottom.options.large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.content_columns.settings.enable_animation.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.content_columns.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.content_columns.blocks.column.settings.image.label"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "t:sections.content_columns.blocks.column.settings.image_alt.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.content_columns.blocks.column.settings.title.label",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.content_columns.blocks.column.settings.description.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.content_columns.presets.name",
      "settings": {
        "heading": "What we offer"
      },
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
