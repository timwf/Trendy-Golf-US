{%- liquid
  assign product = all_products[section.settings.product]

  case section.settings.margin_bottom
    when 'none'
      assign margin_class = ''
    when 'small'
      assign margin_class = 'mb-8'
    when 'medium'
      assign margin_class = 'mb-8 lg:mb-14'
    when 'large'
      assign margin_class = 'mb-14 lg:mb-20'
  endcase
-%}

<section class="product-overview relative {{ margin_class }}" id="product-overview-{{ section.id }}">
  <div class="container-wide">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-10 lg:gap-16">

      {%- comment -%} Left — image {%- endcomment -%}
      <div class="relative bg-taupe-300 overflow-hidden">
        {%- if section.settings.image != blank -%}
          <picture>
            {%- if section.settings.mobile_image != blank -%}
              <source
                media="(max-width: 767px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 480 }} 480w,
                        {{ section.settings.mobile_image | image_url: width: 750 }} 750w"
                sizes="100vw">
            {%- endif -%}
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                      {{ section.settings.image | image_url: width: 800 }} 800w,
                      {{ section.settings.image | image_url: width: 1260 }} 1260w"
              sizes="(min-width: 768px) 50vw, 100vw"
              alt="{{ section.settings.title | escape }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
              class="block w-full h-auto">
          </picture>
        {%- endif -%}
      </div>

      {%- comment -%} Right — content + product {%- endcomment -%}
      <div class="flex flex-col justify-center">
        {%- if section.settings.title != blank -%}
          <h2 class="font-serif text-3xl lg:text-4xl mb-4">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.intro != blank -%}
          <div class="rte mb-6 [&_p]:m-0 [&_p+p]:mt-4">
            {{ section.settings.intro }}
          </div>
        {%- endif -%}

        {%- if product != blank -%}
          <div class="max-w-[280px] mb-6">
            {%- render 'product-card', product: product -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank and section.settings.button_url != blank -%}
          <div>
            <a href="{{ section.settings.button_url }}"
               class="inline-block bg-taupe-900 text-white px-10 py-3 text-sm uppercase tracking-wider transition-colors hover:bg-taupe-600">
              {{ section.settings.button_text | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Overview",
  "tag": "section",
  "class": "product-overview-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 1260 x 1400px"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended: 750 x 360px"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "presets": [
    {
      "name": "Product Overview"
    }
  ]
}
{% endschema %}
