{% comment %}
  Customer reset password — single-column card over full-bleed background.
  Reached from the password-recovery email. Handled entirely by Shopify.
{% endcomment %}

<div class="relative py-20 md:flex md:min-h-[80dvh] md:flex-col md:justify-center">
  <div class="container relative z-1 flex flex-col items-center">
    <div class="w-full max-w-md bg-taupe-300 px-8 py-10 md:px-14">
      <h1 class="mb-4 text-center font-serif text-3xl lg:text-4xl">Reset your password</h1>
      <p class="mb-6 text-center text-sm">Enter a new password for your account.</p>

      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}
          <div class="mb-4 border border-red-600 bg-red-100 p-3 text-sm text-red-700">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="mb-4">
          {% render 'form-input',
            name: 'customer[password]',
            label: 'New password',
            type: 'password',
            required: true,
            autocomplete: 'new-password'
          %}
        </div>

        <div class="mb-6">
          {% render 'form-input',
            name: 'customer[password_confirmation]',
            label: 'Confirm new password',
            type: 'password',
            required: true,
            autocomplete: 'new-password'
          %}
        </div>

        <div class="mb-6 flex justify-center">
          {% render 'form-button', label: 'Reset password', type: 'submit', full_width: true %}
        </div>
      {%- endform -%}

      <p class="mb-0 text-center text-sm">
        <a href="{{ routes.account_login_url }}" class="underline hover:text-clubhouse-green-600">Back to sign in</a>
      </p>
    </div>
  </div>

  {%- if section.settings.background_image != blank -%}
    <img
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      alt="{{ section.settings.background_image.alt | default: '' }}"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
      class="absolute left-0 top-0 size-full object-cover"
      loading="eager"
    >
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Customer reset password",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Full-bleed background image"
    }
  ]
}
{% endschema %}
