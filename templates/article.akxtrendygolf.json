    "text_3": {
      "type": "content-block",
      "blocks": {
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Tucked away in Griffith Park</strong>, Roosevelt offers breathtaking views, including a clear sightline to the Griffith Observatory from Hole 6. It’s a place where golfers of all ages, skill levels, and backgrounds come together, embracing Roosevelt's relaxed and welcoming vibe. For Anthony, these elements made Roosevelt more than just a golf course — they made it home.</p><p>Working closely with Anthony, we designed the AK Roosevelt Capsule to reflect both his personal style and the dynamic, laid-back energy of Roosevelt Golf Course. As a nod to this cherished place, each piece in the collection is adorned with the <strong>longitude and latitude coordinates of Roosevelt Golf Course</strong> — a subtle yet meaningful tribute.</p>"
          }
        }
      },
      "block_order": ["text_1"],
      "settings": {
        "alignment": "left",
        "enable_animation": true
