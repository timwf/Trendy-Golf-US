        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p><em>\"I'll always remember the uneasy feeling I had, at just 7 years old, meeting strangers on the first tee at Roosevelt. That's one reason it's so special to me — every day I was accepted by three new people from all walks of life.\"<br/></em>— <em>Anthony Kim</em></p>"
          }
        }
      },
