    "text_5": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "Pebble Beach, California",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>If you know, you know. The views are unreal, the course is iconic, and the style stakes are high. This is the place to show up looking like you care (but make it effortless). Keep it clean, minimal, and refined.</p><p><strong>What to wear</strong>: Soft palettes, sophisticated details, and head-to-toe looks that move seamlessly from fairway to fireside cocktails.</p>"
          }
        }
      },
      "block_order": [
