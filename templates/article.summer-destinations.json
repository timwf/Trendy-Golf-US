    },
    "text_2": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "Bandon Dunes, Oregon",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>For the purists. Windswept cliffs, rolling dunes, and the kind of dramatic coastal views that make every bogey feel poetic. Bandon is bucket-list golf that calls for layers. Think quarter zips, relaxed tailoring, and a touch of West Coast cool.</p><p><strong>What to wear</strong>: Technical pullovers, elevated rain gear, and a performance pant that moves with you in the wind.</p>"
          }
        }
      },
      "block_order": [
        "heading_1",
        "text_1"
      ],
      "settings": {
        "alignment": "left",
        "enable_animation": true
      }
    },
