    "text_4": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "Big Cedar Lodge, Missouri",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>A hidden gem with major energy. Big Cedar combines resort luxury with rugged Ozark beauty. It's ideal for a buddy trip, family getaway, or solo escape that turns into your favorite new tradition.</p><p><strong>What to wear</strong>: Earth tones, athletic polos, and mid-layers with a bit of an edge. Bonus points for gear that can double as hiking fit.</p>"
          }
        }
      },
      "block_order": [
        "heading_1",
        "text_1"
      ],
      "settings": {
        "alignment": "left",
        "enable_animation": true
