      "settings": {
        "title": "",
        "testimonial_text": "<p>\u201cYou can walk onto a country club and not get in trouble,\u201d Jack says. \u201cThen go to the pub, or go skate, and still be wearing the same thing.\u201d</p>",
        "testimonial_credit": "",
