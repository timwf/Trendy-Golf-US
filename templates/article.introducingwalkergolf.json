    "testimonial_1": {
      "type": "testimonial",
      "settings": {
        "title": "",
        "testimonial_text": "<p>\u201cWe were always kind of playing golf, talking golf, but also working in and around the skate industry,\u201d says co-founder Jack. \u201cIt just felt like the right time to do something in this space, with our background.\u201d</p>",
        "testimonial_credit": "",
        "text_alignment": "center",
        "max_width": 1440,
        "margin_bottom": "medium"
      }
    },
    "text_2": {
      "type": "content-block",
      "blocks": {
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>And what a background it is. With deep experience at brands like Adidas, Volcom, and Nike, the Walker crew didn't come to play small. What they've built is a brand that blends technical function with relaxed Australian cool - always clean, never boring.</p>"
          }
        }
      },
