        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "tilley's brand evolution",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>Tilley Sport's journey began in 1980 with a bucket hat designed for adventurers. Over the years, the brand evolved, introducing the iconic AirFlo hat and now, a comprehensive golf apparel line. Founded by Joe and Kim Newport-Mimran, Tilley Sport was created to fill the gap for stylish, high-performance golf wear.</p>"
          }
        }
      },
      "block_order": [
