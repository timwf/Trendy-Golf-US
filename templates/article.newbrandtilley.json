    "text_3": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "about the collection",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Sleek Lines & Versatile Palettes</strong>: The new collection features sleek designs and a cohesive color palette, making it easy to mix and match. Each piece is crafted for breathability, moisture-wicking, and UV protection, ensuring you look polished on and off the course.</p><p><strong>Innovative Design</strong>: Tilley Sport combines refined aesthetics with cutting-edge technology. Their apparel not only supports peak performance but also complements your personal style, with designs tested for both function and comfort.</p><p><strong>Ethical and Sustainable</strong>: Committed to high standards, Tilley Sport selects eco-friendly materials and adheres to ethical production practices, ensuring that each piece is both durable and responsibly made.</p>"
          }
        }
      },
