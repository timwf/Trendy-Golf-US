          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>Father's Day is right around the corner, and we’ve curated the ultimate gift guide to help you find the perfect present for the special dad in your life. Whether he’s a golf enthusiast or just loves stylish and comfortable apparel, we’ve got you covered with fantastic options at every price point.</p>"
          }
        }
