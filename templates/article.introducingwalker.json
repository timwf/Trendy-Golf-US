        "margin_bottom": "medium"
      }
    },
    "text_5": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "A Brand Built on Mateship",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>More than a brand, Walker is a lifestyle. One built on community, culture, and a deep love of the game.</p>"
          }
        }
      },
      "block_order": ["heading_1", "text_1"],
      "settings": {
        "alignment": "left",
        "enable_animation": true
      }
    },
    "testim_3": {
      "type": "testimonial",
      "settings": {
        "testimonial_text": "<p>\"We've done collaborations with people we actually hang with - like Evan Mock,\" Jack says. \"We just wanted to do fun things with our friends. That's how this all started.\"</p>",
        "text_alignment": "left",
        "max_width": 1440,
        "margin_bottom": "medium"
      }
    },
    "text_6": {
      "type": "content-block",
      "blocks": {
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>Even their kookaburra logo has a story, borrowed from Jack's grandfather's WWII regiment, and now passed down as the family emblem. \"It's personal. It means something,\" Jack said.</p><p>And that's really what Walker Golf is all about: doing something you love, with the people you love, and doing it well.</p>"
          }
        }
      },
      "block_order": ["text_1"],
      "settings": {
        "alignment": "left",
        "enable_animation": true
      }
    },
