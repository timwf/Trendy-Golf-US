    "text_3": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "A Look at Reflo's Latest Collection",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>Reflo recently launched its <strong>Spring-Summer collection</strong>, designed to be:</p><ul><li><strong>Highly versatile</strong> – suitable across multiple sports</li><li><strong>Sustainably innovative</strong> – incorporating the golf industry's first circular apparel solution</li><li><strong>Technically superior</strong> – featuring materials that regulate temperature, wick moisture, and enhance movement</li></ul><p>Unlike fast fashion brands, Reflo takes a <strong>slow, deliberate approach</strong>, ensuring every piece is <strong>precisely designed, rigorously tested, and built to last</strong>.</p>"
          }
        }
      },
