    "text_6": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "A Word from MANORS Creative Director, Luke Davies",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p><em>\u201cThe fairway is safe, predictable\u2014but the real magic in golf happens on the margins. Think of Bubba at the Masters, shaping a shot out of the trees, or those moments when you're forced to improvise, to create something unexpected. That's where the game gets interesting. The 'Drive to Nowhere' collection is built for those moments\u2014when you're off the beaten path.\u201d</em></p>"
          }
        }
      },
