    "text_1": {
      "type": "content-block",
      "blocks": {
        "heading_1": {
          "type": "heading",
          "settings": {
            "text": "Jason Day in Malbon: A Turning Point in Golf Style",
            "tag": "h2",
            "size": "h3",
            "font": "serif"
          }
        },
        "text_1": {
          "type": "text",
          "settings": {
            "text": "<p>If there's one player redefining what it means to <em>look</em> like a modern golfer, it's Jason Day. Known for his powerful swing and major-winning pedigree, Day has always been someone you pay attention to on the leaderboard. But now, he's just as likely to make headlines for what he's wearing.</p><p>And we're here for it.</p>"
          }
        }
      },
      "block_order": [
        "heading_1",
        "text_1"
      ],
      "settings": {
        "alignment": "left",
        "enable_animation": true
      }
    },
    "media_grid_1": {
      "type": "media-grid",
      "blocks": {
