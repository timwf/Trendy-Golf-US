{% doc %}
  Renders an inline SVG icon from the Heroicons outline set.

  @param {string} icon - The icon name (bars-3, x-mark, magnifying-glass, heart, user, user-group, shopping-bag, chevron-right, chevron-down, chevron-left, chevron-double-down, arrow-right, envelope, phone, adjustments-horizontal, truck, trophy, x-mark-solid, magnifying-glass-plus, magnifying-glass-minus, trash, minus, plus, check-circle, exclamation-circle, archive-box, book-open, star, pencil, arrow-right-end-on-rectangle, arrow-uturn-left, arrow-down-tray, gift, chart-bar-square, map-pin, device-phone-mobile, clock, rewards-check, rewards-cross, tier-star, tier-trophy)
  @param {string} [size] - Tailwind size class (default: "size-6")
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'icon', icon: 'shopping-bag', size: 'size-7' %}
{% enddoc %}

{%- liquid
  assign icon_size = size | default: 'size-6'
  assign icon_class = icon_size
  if class
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

