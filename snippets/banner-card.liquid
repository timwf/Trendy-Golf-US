{%- doc -%}
  Renders a single banner card — image background with text overlay and CTA.

  @param {block} block - The Shopify block object
  @param {string} aspect_class - Tailwind aspect ratio class (e.g. "aspect-square", "aspect-[7/9]")
  @param {string} heading_tag - HTML heading tag ("h2" or "h3")
  @param {string} heading_size_class - Tailwind text size classes (e.g. "text-3xl lg:text-4xl")
  @param {boolean} enable_animation - Whether to enable intersection observer fade-up
  @param {number} loading - Card index (1-based) for lazy loading control
  @param {string} sizes - Optional `sizes` attribute for the background image. Defaults to a grid layout assumption.
{%- enddoc -%}

{%- assign card_sizes = sizes | default: '(min-width: 768px) 50vw, 100vw' -%}

<a class="group relative flex flex-col {{ aspect_class }}"
   href="{{ block.settings.link }}"
   {{ block.shopify_attributes }}>

  {%- comment -%} Text overlay — anchored to bottom via mt-auto {%- endcomment -%}
  <div {% if enable_animation %}data-inview="false"{% else %}data-inview="true"{% endif %}
       class="group-inview group/blocks relative z-2 mt-auto w-full p-8 md:p-10">

    {%- comment -%} Heading {%- endcomment -%}
    {%- if block.settings.heading != blank -%}
      <div class="mb-2 text-center text-white md:mb-4
                  opacity-0 -translate-y-14 transition-all duration-1000 ease
                  group-data-[inview=true]/blocks:opacity-100
                  group-data-[inview=true]/blocks:translate-y-0">
        <{{ heading_tag }}><span class="{{ heading_size_class }}">{{ block.settings.heading }}</span></{{ heading_tag }}>
      </div>
    {%- endif -%}

    {%- comment -%} Button / CTA {%- endcomment -%}
    {%- if block.settings.button_label != blank -%}
      <div class="flex justify-center delay-300
                  opacity-0 translate-y-14 transition-all duration-1000 ease
                  group-data-[inview=true]/blocks:opacity-100
                  group-data-[inview=true]/blocks:translate-y-0">
        <span class="flex items-center gap-2 text-sm tracking-wider uppercase -mr-2 text-white">
          <span>{{ block.settings.button_label }}</span>
          {%- render 'icon', icon: 'chevron-right', size: 'size-4' -%}
        </span>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Hover overlay {%- endcomment -%}
  <div class="absolute left-0 top-0 z-1 size-full
              bg-gradient-to-b from-black/10 to-black/30
              opacity-0 transition-opacity duration-500
              group-hover:opacity-100"></div>

  {%- comment -%} Bottom gradient — always visible {%- endcomment -%}
  <div class="absolute bottom-0 left-0 z-1 h-1/3 w-full
              bg-gradient-to-b from-black/0 to-black/60"></div>

  {%- comment -%} Background image {%- endcomment -%}
  {%- if block.settings.image != blank -%}
    <img
      src="{{ block.settings.image | image_url: width: 1280 }}"
      srcset="{{ block.settings.image | image_url: width: 480 }} 480w,
              {{ block.settings.image | image_url: width: 750 }} 750w,
              {{ block.settings.image | image_url: width: 1080 }} 1080w,
              {{ block.settings.image | image_url: width: 1280 }} 1280w"
      sizes="{{ card_sizes }}"
      alt="{{ block.settings.heading | escape }}"
      class="absolute left-0 top-0 size-full object-cover"
      width="1280"
      height="1280"
      loading="{% if loading <= 2 %}eager{% else %}lazy{% endif %}">
  {%- else -%}
    <div class="absolute left-0 top-0 size-full bg-taupe-300"></div>
  {%- endif -%}
</a>
